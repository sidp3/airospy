name: CI — Build, Push & Deploy

on:
  push:
    branches: [ main ]

jobs:
  build-and-push:
    name: Build and push image
    runs-on: ubuntu-latest
    outputs:
      image: ${{ steps.push-image.outputs.image }}
    steps:
      - uses: actions/checkout@v4

      - name: Set up QEMU
        uses: docker/setup-qemu-action@v2

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v2

      - name: Login to GHCR
        run: echo "${{ secrets.GITHUB_TOKEN }}" | docker login ghcr.io -u "${{ github.actor }}" --password-stdin

      - name: Build and push image
        id: push-image
        run: |
          IMAGE=ghcr.io/${{ github.repository_owner }}/aerospy:latest
          docker build -t $IMAGE .
          docker push $IMAGE
          echo "::set-output name=image::$IMAGE"

  deploy:
    name: Deploy to remote host
    runs-on: ubuntu-latest
    needs: build-and-push
    steps:
      - name: Deploy via SSH
        uses: appleboy/ssh-action@master
        with:
          host: ${{ secrets.SSH_HOST }}
          username: ${{ secrets.SSH_USER }}
          key: ${{ secrets.SSH_PRIVATE_KEY }}
          port: ${{ secrets.SSH_PORT }}
          script: |
            set -euo pipefail
            IMAGE=ghcr.io/${{ github.repository_owner }}/aerospy:latest
            echo "Pulling $IMAGE"
            docker pull $IMAGE
            docker stop aerospy || true
            docker rm aerospy || true

            # write env file (values may be empty if secrets not provided)
            cat > aerospy_env <<'EOF'
EMAILJS_SERVICE_ID=${{ secrets.EMAILJS_SERVICE_ID }}
EMAILJS_TEMPLATE_ID=${{ secrets.EMAILJS_TEMPLATE_ID }}
EMAILJS_PUBLIC_KEY=${{ secrets.EMAILJS_PUBLIC_KEY }}
EOF

            # run container (adjust ports as needed)
            docker run -d --restart unless-stopped --env-file ./aerospy_env -p 80:8501 --name aerospy $IMAGE
